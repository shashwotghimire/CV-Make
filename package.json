{
  "name": "cvmake",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "postinstall": "pnpm db:generate",
    "db:generate": "pnpm --filter @cvmake/db db:generate",
    "db:migrate": "pnpm --filter @cvmake/db db:migrate",
    "db:push": "pnpm --filter @cvmake/db db:push",
    "db:seed": "pnpm --filter @cvmake/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  }
}
